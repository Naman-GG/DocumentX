# ── Server endpoints ────────────────────────────────────────
# Base URL of the DocumentX server (HTTP, for AI requests).
VITE_SERVER_URL=http://localhost:3001
# WebSocket URL of the DocumentX server (Yjs sync + WebRTC signaling).
# Use wss:// in production (e.g. wss://your-app.onrender.com).
VITE_WS_URL=ws://localhost:3001

# ── Firebase web config ─────────────────────────────────────
# From Firebase console → Project settings → Your apps → SDK setup (config).
# These values are public by design (safe to expose in the client bundle).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Local development against the Firebase Emulator Suite ────
# Set to "true" to use local emulators instead of a real project
# (then only VITE_FIREBASE_PROJECT_ID matters, e.g. demo-documentx).
VITE_USE_FIREBASE_EMULATOR=false

# ── Optional TURN server for voice across restrictive networks ─
# Get free credentials from e.g. Metered Open Relay. STUN works without this.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
