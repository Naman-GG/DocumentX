# Groq API key — required for the AI features. Free key at https://console.groq.com/keys
GROQ_API_KEY=your_key_here

# Port the server listens on (HTTP + WebSocket share this port).
# Render sets PORT automatically; leave unset there.
PORT=3001

# Firebase Admin service-account JSON (one line) — required to verify auth tokens
# and read documents. From Firebase console → Project settings → Service accounts →
# Generate new private key. Paste the entire JSON as a single-line string.
# SERVER-ONLY SECRET — never expose this to the client.
FIREBASE_SERVICE_ACCOUNT=

# Comma-separated client origin(s) allowed by CORS in production
# (e.g. https://your-app.vercel.app). Leave unset for local dev (allows all).
CLIENT_ORIGIN=

# ── Local development against the Firebase Emulator Suite ────
# Instead of FIREBASE_SERVICE_ACCOUNT, set these to use local emulators:
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_PROJECT_ID=demo-documentx
